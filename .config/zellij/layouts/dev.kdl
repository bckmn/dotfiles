// Sample development layout
// Place at: ~/.config/zellij/layouts/dev.kdl
// Usage:    zellij --layout dev
//           zellij action new-tab --layout ~/.config/zellij/layouts/dev.kdl

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="code" focus=true {
        pane split_direction="vertical" {
            pane size="60%" name="editor" command="nvim"

            pane size="40%" name="claude" command="claude"
        }
    }

    tab name="git" {
        pane name="git"
    }

    tab name="workers" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
